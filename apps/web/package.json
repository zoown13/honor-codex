{
  "name": "@honor/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "pnpm --filter @honor/core build",
    "dev": "next dev",
    "build": "next build",
    "postbuild": "node scripts/assert-static-output.mjs",
    "start": "npx serve out",
    "pretest": "pnpm --filter @honor/core build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint app components data lib scripts tests --max-warnings=0"
  },
  "dependencies": {
    "@honor/core": "workspace:*",
    "next": "^16.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.39.1",
    "jsdom": "^27.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.49.0",
    "vitest": "4.1.10"
  }
}
